exec-once = /nix/store/5gln2rkcjx93cr5x0rr3wqrxjdmshd2f-dbus-1.16.2/bin/dbus-update-activation-environment --systemd DISPLAY HYPRLAND_INSTANCE_SIGNATURE WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE && systemctl --user stop hyprland-session.target && systemctl --user start hyprland-session.target
$browser=brave
$fileManager=nautilus
$ipc=noctalia-shell ipc call
$mainMod=mod5
$terminal=ghostty
animations {
  bezier=myBezier, 0.05, 0.9, 0.1, 1.05
  animation=windows, 1, 5, myBezier, popin 80%
  animation=windowsOut, 1, 5, myBezier, popin 80%
  animation=layers, 1, 5, myBezier, fade
  animation=layersIn, 1, 5, myBezier, fade
  animation=layersOut, 1, 5, myBezier, fade
  animation=fade, 1, 5, myBezier
  animation=workspaces, 1, 5, myBezier, slide
  animation=specialWorkspaceIn, 1, 5, myBezier, fade
  animation=specialWorkspaceOut, 1, 5, myBezier, fade
  enabled=yes
}

bind=$mainMod, return, exec, $terminal
bind=$mainMod, q, killactive,
bind=$mainMod, b, exec, $browser
bind=$mainMod, f, exec, $fileManager
bind=$mainMod, V, togglefloating,
bind=$mainMod, m, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit
bind=mod5 Shift, F, fullscreen,
bind=$mainMod, y, exec, bash -c "alacritty --title yazi-float -e fish -c \"y\""
bind=$mainMod, backspace, exec, hyprctl switchxkblayout all next
bind=mod5, SPACE, exec, $ipc launcher toggle
bind=mod5, comma, exec, $ipc controlCenter toggle
bind=mod5, equal, exec, $ipc settings toggle
bind=mod5, period, exec, $ipc wallpaper toggle
bind=$mainMod SHIFT SUPER, a, exec, hyprctl keyword animations:enabled $(expr 1 - $(hyprctl getoption animations:enabled -j | jq '.int'))
bind=$mainMod, a, movefocus, l
bind=$mainMod, s, movefocus, r
bind=$mainMod, w, movefocus, u
bind=$mainMod, r, movefocus, d
bind=$mainMod shift, a, movewindow, l
bind=$mainMod shift, s, movewindow, r
bind=$mainMod shift, w, movewindow, u
bind=$mainMod shift, r, movewindow, d
bind=$mainMod, 1, workspace, 1
bind=$mainMod SHIFT, 1, movetoworkspacesilent, 1
bind=$mainMod, 2, workspace, 2
bind=$mainMod SHIFT, 2, movetoworkspacesilent, 2
bind=$mainMod, 3, workspace, 3
bind=$mainMod SHIFT, 3, movetoworkspacesilent, 3
bind=$mainMod, 4, workspace, 4
bind=$mainMod SHIFT, 4, movetoworkspacesilent, 4
bind=$mainMod, 5, workspace, 5
bind=$mainMod SHIFT, 5, movetoworkspacesilent, 5
bind=$mainMod, 6, workspace, 6
bind=$mainMod SHIFT, 6, movetoworkspacesilent, 6
bind=$mainMod, 7, workspace, 7
bind=$mainMod SHIFT, 7, movetoworkspacesilent, 7
bind=$mainMod, 8, workspace, 8
bind=$mainMod SHIFT, 8, movetoworkspacesilent, 8
bind=$mainMod, 9, workspace, 9
bind=$mainMod SHIFT, 9, movetoworkspacesilent, 9
bind=$mainMod, 0, workspace, 10
bind=$mainMod SHIFT, 0, movetoworkspacesilent, 10

bindel=, XF86AudioRaiseVolume, exec, $ipc volume increase
bindel=, XF86AudioLowerVolume, exec, $ipc volume decrease
bindel=, XF86MonBrightnessUp, exec, $ipc brightness increase
bindel=, XF86MonBrightnessDown, exec, $ipc brightness decrease

bindl=, XF86AudioMute, exec, $ipc volume muteOutput
bindl=, XF86AudioNext, exec, playerctl next
bindl=, XF86AudioPause, exec, playerctl play-pause
bindl=, XF86AudioPlay, exec, playerctl play-pause
bindl=, XF86AudioPrev, exec, playerctl previous

bindm=$mainMod, mouse:272, movewindow
bindm=$mainMod, mouse:273, resizewindow

cursor {
  no_hardware_cursors=true
}

decoration {
  blur {
    enabled=true
    new_optimizations=true
    passes=3
    size=8
    xray=true
  }

  shadow {
    color=rgba(1a1a1aee)
    enabled=true
    range=4
    render_power=3
  }
  active_opacity=1.000000
  rounding=20
  rounding_power=2
}

dwindle {
  preserve_split=true
  pseudotile=true
}

env=HYPRCURSOR_THEME,macOS-hypr
env=HYPRCURSOR_SIZE,28
env=XCURSOR_SIZE,24

exec-once=noctalia-shell
exec-once=systemctl --user start hyprpolkitagent

general {
  allow_tearing=false
  border_size=3
  col.active_border=rgb(ffb2b8)
  col.inactive_border=rgb(131313)
  gaps_in=5
  gaps_out=10
  layout=dwindle
  resize_on_border=false
}

input {
  touchpad {
    natural_scroll=false
  }
  follow_mouse=1
  kb_layout=us,us
  kb_options=altwin:swap_lalt_lwin
  kb_variant=colemak_dh,
  sensitivity=-0.600000
}

layerrule=blur on, match:namespace noctalia-background-.*$
layerrule=ignore_alpha 0.5, match:namespace noctalia-background-.*$
layerrule=blur_popups on, match:namespace noctalia-background-.*$

master {
  new_status=master
}

windowrule=match:class com.mitchellh.ghostty, opacity 0.85 0.75
windowrule=match:class brave-browser, opacity 0.95 0.9
windowrule=match:class steam, opacity 0.85 0.8
windowrule {
  name=yazi-floating-config
  center=on
  float=on
  match:title=^yazi-float$
  size=1000 700
}
windowrule {
  name=suppress-maximize-events
  match:class=.*
  suppress_event=maximize
}
windowrule {
  name=fix-xwayland-drags
  match:class=^$
  match:float=true
  match:title=^$
  match:xwayland=true
  no_focus=true
}
windowrule {
  name=move-hyprland-run
  float=yes
  match:class=hyprland-run
  move=20 monitor_h-120
}
monitor=,1920x1080@144,0x0, 1

source = /home/mic/.config/hypr/noctalia/noctalia-colors.conf

